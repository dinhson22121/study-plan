# Production environment template for the admin web app.
# Copy to `.env.production` (git-ignored) and fill in real values before `npm run build`.
# All variables MUST be prefixed with VITE_ to be exposed to the client bundle.

# Base URL of the backend API (include the version prefix). REQUIRED.
VITE_API_BASE_URL=https://api.example.com/api/v1

# Display name shown in the UI. Optional (defaults to "Edu Admin").
VITE_APP_NAME=Edu Admin

# Parse-job polling interval in milliseconds. Optional (defaults to 5000).
VITE_POLL_INTERVAL_MS=5000

# Max upload size in bytes. Optional (defaults to 20971520 = 20 MiB).
VITE_UPLOAD_MAX_FILE_SIZE_BYTES=20971520

# Deployment environment label reported to monitoring. Optional (defaults to Vite MODE).
VITE_APP_ENV=production

# Sentry DSN for optional error monitoring. Leave blank to disable (no-op).
# When set, requires @sentry/browser to be installed; otherwise it is ignored at runtime.
VITE_SENTRY_DSN=
