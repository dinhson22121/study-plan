# Production environment variables for the Edu backend.
# Copy to .env (gitignored) or inject via your secret manager / orchestrator.
# Every EDU_* var overrides the matching key in config.yaml.

# Core
EDU_ENV=production
EDU_PORT=:8080
EDU_TIMEZONE=Asia/Ho_Chi_Minh

# Postgres — production MUST use sslmode=require (or stricter)
EDU_POSTGRES_URL=postgres://USER:PASSWORD@HOST:5432/eduapp?sslmode=require

# Redis
EDU_REDIS_URL=redis://HOST:6379/0

# Kafka (comma-separated)
EDU_KAFKA_BROKERS=HOST:9092

# JWT — REQUIRED, strong & non-default, >=32 chars.
# Generate: openssl rand -base64 48
EDU_JWT_SECRET=

# FCM (real push) — path to the service-account JSON mounted into the container
EDU_FCM_CREDENTIALS_FILE=/app/config/firebase-service-account.json

# S3 / object storage
EDU_S3_ENDPOINT=
EDU_S3_REGION=us-east-1
EDU_S3_ACCESS_KEY=
EDU_S3_SECRET_KEY=
EDU_S3_BUCKET=edu-assets
EDU_S3_USE_PATH_STYLE=false

# Auth rate limiting
EDU_RATELIMIT_AUTH_REQUESTS=10
EDU_RATELIMIT_AUTH_WINDOW=1m
