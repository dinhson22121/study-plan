# Expo public env (inlined at build time). Copy to .env for local dev.
# EAS build profiles in eas.json set these per environment.

# Backend API base. Android emulator reaches the host via 10.0.2.2.
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080/api/v1

# Optional Sentry DSN — empty disables crash reporting.
EXPO_PUBLIC_SENTRY_DSN=
